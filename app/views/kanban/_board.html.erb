<%# Wrap in a form so Redmine's built-in contextMenuInit() works on cards %>
<form id="kb-context-menu-form"
      data-cm-url="<%= issues_context_menu_path %>"
      onsubmit="return false;">

  <div class="kb-board" role="region" aria-label="<%= l(:label_kanban_board) %>">
    <% if @swimlanes %>
      <%# Swimlane mode: one row of columns per group %>
      <% @swimlanes.each do |lane| %>
        <%= render partial: 'swimlane', locals: {
          lane:        lane,
          statuses:    @statuses,
          wip_limits:  @wip_limits,
          status_counts: @status_counts
        } %>
      <% end %>
    <% else %>
      <div class="kb-columns">
        <% @columns.each do |col| %>
          <%= render partial: 'column', locals: {
            status:       col[:status],
            issues:       col[:issues],
            count:        col[:count],
            closed:       col[:closed],
            wip_limit:    @wip_limits[col[:status].id],
            global_count: col[:count]
          } %>
        <% end %>
      </div>
    <% end %>
  </div>
</form>
