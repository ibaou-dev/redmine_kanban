<% blocked = @blocked_ids&.include?(issue.id) %>
<div class="<%= kanban_card_classes(issue) %> hascontextmenu<%= ' kb-blocked' if blocked %>"
     data-issue-id="<%= issue.id %>"
     data-allowed-statuses="<%= kanban_allowed_statuses_json(issue) %>"
     data-issue-url="<%= issue_path(issue) %>"
     data-blocked="<%= blocked ? 'true' : 'false' %>"
     <% if issue.parent_id %>data-parent-id="<%= issue.parent_id %>"<% end %>
     tabindex="0"
     role="article"
     aria-label="<%= "#{issue.tracker.name} ##{issue.id}: #{issue.subject}" %>">

  <%# Hidden checkbox enables Redmine's built-in right-click context menu %>
  <input type="checkbox"
         name="ids[]"
         value="<%= issue.id %>"
         class="kb-card-checkbox"
         aria-hidden="true"
         style="display:none" />

  <div class="kb-card-header">
    <span class="kb-card-tracker-tag"><%= issue.tracker.name %></span>
    <div class="kb-card-header-right">
      <% if blocked %>
        <span class="kb-blocked-icon" title="<%= l(:label_blocked) %>">&#128274;</span>
      <% end %>
      <a href="<%= issue_path(issue) %>"
         class="kb-card-id"
         title="<%= "#{l(:label_issue)} ##{issue.id}" %>">#<%= issue.id %></a>
      <button class="kb-card-menu-btn js-contextmenu"
              type="button"
              aria-label="<%= l(:button_actions) %>"
              title="<%= l(:button_actions) %>">&#8942;</button>
    </div>
  </div>

  <a href="<%= issue_path(issue) %>" class="kb-card-subject-link">
    <div class="kb-card-subject" title="<%= issue.subject %>"><%= issue.subject %></div>
  </a>

  <%# Detailed-mode: description snippet (always shown in detailed, blank if no description) %>
  <div class="kb-card-description kb-detail-only">
    <% if issue.description.present? %>
      <%= truncate(issue.description, length: 120, escape: false) %>
    <% else %>
      <span class="kb-no-description">—</span>
    <% end %>
  </div>

  <%# Detailed-mode: author + creation date %>
  <div class="kb-card-author kb-detail-only">
    <%= issue.author.name %> &middot; <%= format_date(issue.created_on) %>
  </div>

  <%# Normal + detailed: progress bar (shown when done_ratio > 0) %>
  <% if issue.done_ratio > 0 %>
    <div class="kb-card-progress kb-normal-up" title="<%= "#{issue.done_ratio}% #{l(:field_done_ratio)}" %>">
      <div class="kb-card-progress-bar" style="width:<%= issue.done_ratio %>%"></div>
    </div>
  <% end %>

  <div class="kb-card-footer">
    <div class="kb-card-meta">
      <%= kanban_priority_label(issue) %>
      <%= kanban_subtask_badge(issue) %>
      <% if issue.due_date %>
        <span class="kb-card-due<%= ' kb-overdue' if issue.overdue? %>"
              title="<%= l(:field_due_date) %>: <%= format_date(issue.due_date) %>">
          <%= format_date(issue.due_date) %>
        </span>
      <% end %>
      <%# Detailed-mode: version and attachment count %>
      <% if issue.fixed_version %>
        <span class="kb-card-version kb-detail-only"
              title="<%= l(:field_fixed_version) %>">&#127959; <%= issue.fixed_version.name %></span>
      <% end %>
      <% attach_count = @attachment_counts&.dig(issue.id).to_i %>
      <% if attach_count > 0 %>
        <span class="kb-card-attachments kb-detail-only"
              title="<%= pluralize(attach_count, l(:label_attachment)) %>">&#128206; <%= attach_count %></span>
      <% end %>
    </div>
    <div class="kb-card-right">
      <%= kanban_assignee_cell(issue.assigned_to) %>
    </div>
  </div>
</div>
